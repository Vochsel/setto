# ───────────────────────────── Site ────────────────────────────────
# Public origin of the deployed app. Used as the metadataBase for absolute
# Open Graph / Twitter URLs. Defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ───────────────────────────── Convex ──────────────────────────────
# Created automatically by `npx convex dev`. It writes CONVEX_DEPLOYMENT and
# prints your deployment URL — copy it into NEXT_PUBLIC_CONVEX_URL.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ──────────────────────────── WorkOS ───────────────────────────────
# From the WorkOS dashboard (https://dashboard.workos.com).
WORKOS_API_KEY=sk_...
WORKOS_CLIENT_ID=client_...
# 32+ char secret. Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=
# Must match a redirect URI configured in WorkOS. AuthKit 4.x reads the
# middleware redirect from the NEXT_PUBLIC_ copy, so set both.
WORKOS_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# ──────────────────────── Campaign copywriter (OpenAI) ─────────────────
# The campaign copy writer is a streaming AI-SDK chat that runs in the Next.js
# route app/api/campaigns/[id]/copy-chat — so it needs the OpenAI key in the
# FRONTEND env (not just the Convex deployment). Set it here too.
OPENAI_API_KEY=sk-...
# Optional: pin the OpenAI text model used for copy (defaults to the registry,
# convex/lib/textModels.ts — currently gpt-5).
# OPENAI_TEXT_MODEL=gpt-5

# ─── Set these in the CONVEX deployment env (npx convex env set NAME val) ───
# WORKOS_CLIENT_ID     — your application client id (same as above).
# WORKOS_JWT_CLIENT_ID — the environment client id WorkOS puts in the token
#                        `iss` (https://api.workos.com/user_management/<id>).
#                        Often differs from the app client id; read it from a
#                        token's `iss` claim. Used to validate JWTs in Convex.
# GOOGLE_MAPS_API_KEY  — Google key with Street View Static API enabled.
# --- image generation providers (set the ones you want to use) ---
# FAL_KEY              — fal.ai key (FLUX, Imagen, Ideogram, Recraft, nano-banana).
# OPENAI_API_KEY       — OpenAI key for GPT Image models AND campaign ad-copy (GPT).
# OPENAI_TEXT_MODEL    — (optional) override the chat model used for campaign
#                        copy (default "gpt-4o"), e.g. "gpt-4.1".
# GOOGLE_AI_API_KEY    — Google AI (Gemini) key for Nano Banana / Gemini 2.5 Flash Image.

# ──────────────────────── Google Maps (browser) ────────────────────
# Key with Maps JavaScript API + Places API enabled (restrict to your domain).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional: a Map ID for vector/styled maps + advanced markers.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
